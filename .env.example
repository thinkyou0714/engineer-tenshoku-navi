# Copy to .env and fill. All optional — sensible defaults are used if unset.

# Google Analytics 4. If set, an opt-in consent banner appears and GA loads ONLY
# after the visitor consents. If unset, no analytics / no banner.
# PUBLIC_GA_ID=G-XXXXXXXXXX

# Deploy target (domain move = just these two):
#   GitHub Pages (default): leave both unset
#   Vercel / custom domain (root path): set SITE_URL and SITE_BASE=""
# SITE_URL=https://your-domain.example
# SITE_BASE=

# Affiliate offer URLs (see src/data/offers.mjs — env var beats the url field there).
# After each ASP approval, set the matching variable (or edit offers.mjs) and rebuild:
# every article CTA written as [text](offer:<id>) becomes a real sponsored link.
# Unset = the CTA stays a harmless "#" placeholder.
# OFFER_URL_LEVTECH=https://px.a8.net/...            # レバテックキャリア
# OFFER_URL_BIZREACH=https://px.a8.net/...           # ビズリーチ
# OFFER_URL_DODA=https://px.a8.net/...               # doda
# OFFER_URL_GEEKLY=https://px.a8.net/...             # Geekly
# OFFER_URL_LEVTECH_FREELANCE=https://px.a8.net/...  # レバテックフリーランス

# IndexNow (scripts/indexnow-submit.mjs). Generate a key (e.g. `openssl rand -hex 16`),
# put the key string into public/<KEY>.txt, deploy, then set the key here.
# Unset = the script runs as a dry-run (prints the payload, submits nothing).
# INDEXNOW_KEY=abcdef0123456789abcdef0123456789
# Optional override if the key file is not next to the sitemap:
# INDEXNOW_KEY_LOCATION=https://your-domain.example/abcdef0123456789abcdef0123456789.txt

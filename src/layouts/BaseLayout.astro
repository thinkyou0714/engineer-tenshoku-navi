---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Disclosure from '../components/Disclosure.astro';
import Analytics from '../components/Analytics.astro';
import { SITE } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  path?: string;
  ogType?: string;
  schemas?: unknown[];
  noindex?: boolean;
}
const props = Astro.props;
---
<!doctype html>
<html lang={SITE.lang}>
  <head>
    <BaseHead {...props} />
  </head>
  <body>
    <a class="skip-link" href="#main">本文へスキップ</a>
    <Header />
    <Disclosure />
    <main id="main" class="container">
      <slot />
    </main>
    <Footer />
    <Analytics />
    <script is:inline>
      // ペンディングCTA(href="#" data-offer-pending)の既定挙動(ページ先頭へジャンプ)を
      // 全ページで抑止する。クリック自体は Analytics の需要計測(affiliate_click,
      // active:false)に流れる。ASP承認で実URL化されると data-offer-pending が消え無効化。
      document.addEventListener('click', function (e) {
        var t = e.target && e.target.closest ? e.target.closest('[data-offer-pending]') : null;
        if (t) e.preventDefault();
      });
    </script>
  </body>
</html>

---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import AuthorBox from '../components/AuthorBox.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Toc from '../components/Toc.astro';
import { articleSchema, breadcrumbSchema, faqSchema, itemListSchema } from '../utils/schema';
import { SITE } from '../data/site';
import type { Faq } from '../data/site';
import type { MarkdownHeading } from 'astro';

interface Props {
  title: string;
  description: string;
  path: string;
  slug: string;
  publishDate: Date;
  updatedDate?: Date;
  faq?: Faq[];
  headings?: MarkdownHeading[];
  itemList?: string[];
}
const { title, description, path, slug, publishDate, updatedDate, faq, headings, itemList } =
  Astro.props;

const iso = (d: Date) => d.toISOString();
const fmt = (d: Date) => d.toISOString().slice(0, 10);

const crumbs = [{ name: 'ホーム', url: '/' }, { name: title, url: path }];
const schemas = [
  articleSchema({
    title,
    description,
    path,
    datePublished: iso(publishDate),
    dateModified: iso(updatedDate ?? publishDate),
  }),
  breadcrumbSchema(crumbs),
  faqSchema(faq),
  // 比較記事のみ frontmatter の itemList から出力(未指定なら null → graph() が除外)。
  itemListSchema(itemList),
];
---
<BaseLayout
  title={title}
  description={description}
  path={path}
  ogType="article"
  schemas={schemas}
  ogImage={`/og/${slug}.png`}
  publishedTime={iso(publishDate)}
  modifiedTime={updatedDate ? iso(updatedDate) : undefined}
>
  <Breadcrumb items={crumbs} />
  <article class="post">
    <h1>{title}</h1>
    <p class="post-meta">
      <time datetime={fmt(publishDate)}>公開 {fmt(publishDate)}</time>
      {updatedDate && <> ・ <time datetime={fmt(updatedDate)}>更新 {fmt(updatedDate)}</time></>}
      ・ 執筆 {SITE.author.name}
    </p>
    <Toc headings={headings} />
    <div class="prose">
      <slot />
    </div>
    <AuthorBox />
    <RelatedPosts currentId={slug} />
  </article>
</BaseLayout>
